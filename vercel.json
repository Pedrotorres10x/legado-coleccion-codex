{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/share/(?P<slug>[^/]+)",
      "dest": "https://vrywyqpxmmzikaedjoxt.supabase.co/functions/v1/property-og?slug=$slug"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}